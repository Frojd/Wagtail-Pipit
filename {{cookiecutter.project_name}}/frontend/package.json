{
  "name": "frontend_nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p {{cookiecutter.nextjs_port}}",
    "build": "next build",
    "build:local": "IGNORE_SENTRY=1 next build",
    "start": "PORT={{cookiecutter.nextjs_port}} node .next/standalone/server.js",
    "storybook": "storybook dev -p 3001",
    "build-storybook": "storybook build",
    "fixcode": "prettier --write .",
    "fixcode:check": "prettier --check .",
    "new": "node cli/bin.js new",
    "new:container": "node cli/bin.js new --container",
    "test": "jest --watch",
    "test:ci": "jest --ci --runInBand --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.39.0",
    "i18next": "^25.6.3",
    "next": "16.1.6",
    "next-i18next": "^15.4.2",
    "prop-types": "^15.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.9",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "storybook": "^10.2.9",
    "@storybook/nextjs-vite": "10.2.14"
  }
}
